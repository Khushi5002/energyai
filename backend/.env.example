###############################################################################
# Required for the running API
###############################################################################
# Create a key at https://console.groq.com/keys.
GROQ_API_KEY=

# Optional. Without it, the app uses built-in fallback headlines.
# Create a key at https://newsapi.org/.
NEWSAPI_KEY=

# Comma-separated frontend origins permitted to call this API.
# Example production value: https://your-project.vercel.app
CORS_ORIGINS=http://localhost:5173

###############################################################################
# Required only when running: python -m app.seed
###############################################################################
MONGO_URL=mongodb://localhost:27017
DB_NAME=energy_resilience
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=testpass123
